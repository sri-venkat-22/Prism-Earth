# Frontend environment (public vars must be prefixed NEXT_PUBLIC_).
# Copy to .env.local for local runs. In docker-compose these are injected.

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_DOCS_URL=http://localhost:8000/docs
NEXT_PUBLIC_API_HEALTH_URL=http://localhost:8000/api/v1/health
