# Root environment for docker-compose. Copy to .env to override the dev defaults.
# (All values have sane defaults in docker-compose.yml, so .env is optional.)

# PostgreSQL / PostGIS
POSTGRES_USER=prism
POSTGRES_PASSWORD=prism
POSTGRES_DB=prism_earth
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Service ports (host side)
BACKEND_PORT=8000
FRONTEND_PORT=3000
