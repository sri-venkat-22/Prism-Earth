# Backend environment variables (prefix: PRISM_). Copy to .env for local runs.
# When using docker-compose, these are provided by the root .env / compose file.

PRISM_APP_ENV=development
PRISM_DEBUG=true
PRISM_LOG_LEVEL=INFO
PRISM_LOG_JSON=false

# PostgreSQL / PostGIS
PRISM_POSTGRES_HOST=localhost
PRISM_POSTGRES_PORT=5432
PRISM_POSTGRES_USER=prism
PRISM_POSTGRES_PASSWORD=prism
PRISM_POSTGRES_DB=prism_earth

# Redis
PRISM_REDIS_URL=redis://localhost:6379/0

# Config files directory (defaults to <repo>/configs)
# PRISM_CONFIG_DIR=/configs

# Spatial data seed directory (defaults to <repo>/datasets/telangana)
# PRISM_SEED_DATA_DIR=/datasets/telangana

# Google Earth Engine service-account auth (SRS §19.3).
# See docs/google_earth_engine_setup.md for the Google Cloud setup steps.
# Keep the key in the gitignored <repo>/secrets/ directory — never commit it.
# PRISM_EARTH_ENGINE_SERVICE_ACCOUNT=prism-earth-gee@<project>.iam.gserviceaccount.com
# PRISM_EARTH_ENGINE_KEY_FILE=/absolute/path/to/secrets/<key>.json
# PRISM_EARTH_ENGINE_PROJECT=<gcp-project-id>

# AI pipeline (SRS §9, §14, §6.5): the Planner and Synthesizer for POST /api/v1/ask.
# Model is a LiteLLM route; the provider key is read from the provider's own env
# var (e.g. ANTHROPIC_API_KEY / OPENAI_API_KEY) unless PRISM_LLM_API_KEY is set.
# PRISM_LLM_MODEL=anthropic/claude-opus-4-8
# PRISM_LLM_TEMPERATURE=0.0
# PRISM_LLM_MAX_TOKENS=1024
# PRISM_LLM_TIMEOUT=30.0
# PRISM_LLM_API_KEY=
