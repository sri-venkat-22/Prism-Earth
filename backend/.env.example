# Backend environment variables (prefix: PRISM_). Copy to .env for local runs.
# When using docker-compose, these are provided by the root .env / compose file.

PRISM_APP_ENV=development
PRISM_DEBUG=true
PRISM_LOG_LEVEL=INFO
PRISM_LOG_JSON=false

# PostgreSQL / PostGIS
PRISM_POSTGRES_HOST=localhost
PRISM_POSTGRES_PORT=5432
PRISM_POSTGRES_USER=prism
PRISM_POSTGRES_PASSWORD=prism
PRISM_POSTGRES_DB=prism_earth

# Redis
PRISM_REDIS_URL=redis://localhost:6379/0

# Config files directory (defaults to <repo>/configs)
# PRISM_CONFIG_DIR=/configs

# Google Earth Engine (Phase 2 — leave blank in Phase 0)
# PRISM_EARTH_ENGINE_SERVICE_ACCOUNT=
# PRISM_EARTH_ENGINE_KEY_FILE=
